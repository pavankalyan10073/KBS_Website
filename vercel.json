{
  "version": 2,
  "builds": [
    {
      "src": "kbs-luxe-front-main/.output/functions/__server.func/index.mjs",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["kbs-luxe-front-main/.output/**/*"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
